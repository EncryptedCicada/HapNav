/*
 * Board overlay for Seeed XIAO nRF52840 (haptic wristband).
 *
 * I2C topology (on the XIAO's Qwiic-compatible D4/D5 header → SoC i2c1):
 *   i2c1 ──┬── PCA9546A 4-channel mux @ 0x70
 *          ├── ch0 → DA7280 @ 0x4A   (LEFT,         outer-left LRA)
 *          ├── ch1 → DA7280 @ 0x4A   (CENTER-LEFT,  inner-left LRA)
 *          ├── ch2 → DA7280 @ 0x4A   (CENTER-RIGHT, inner-right LRA)
 *          └── ch3 → DA7280 @ 0x4A   (RIGHT,        outer-right LRA)
 *
 * All four DA7280s share the same 7-bit address — they're isolated by the
 * mux. We don't declare per-driver child nodes here because the haptics
 * module talks to the bus directly (mirrors the pin's sensor pattern);
 * only the bus itself needs config.
 *
 * `i2c1` is the bus the xiao_ble board file routes to D4 (SDA / P0.04) and
 * D5 (SCL / P0.05) — the standard Qwiic pinout for this board. The board
 * common dtsi already enables it and assigns pinctrl, so this overlay just
 * raises the bus rate to 400 kHz.
 */

&i2c1 {
	clock-frequency = <I2C_BITRATE_FAST>;  /* 400 kHz */
};
